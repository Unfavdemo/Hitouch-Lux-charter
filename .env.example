# Copy to `.env.local` for local development (never commit real secrets).

# --- Local demo (no Twilio/Resend/Smith keys) ---
# NEXT_PUBLIC_DEMO_MODE=1              # Demo Smith callout; dev webhook bypass with x-hitouch-demo-webhook: 1
# Print checklist + URLs: `npm run test:auth`
# Full demo dataset: `npm run seed:all`  (password HitouchDemo2026! for all seeded users)
# Seed two demo corporate leads with portal grants: `npm run seed:corporate-demo`
# One-click corporate portal sign-in while `next dev` runs:
#   DEV_AUTH_HELPER=1
# Then open http://localhost:3000/dev/auth-test (never set in production).

# Optional: Neon Postgres connection string. When set, B2B leads use Prisma against
# `corporate_leads`, `event_leads`, and `experience_leads`. Booking inquiries require DATABASE_URL.
# Run `npm run db:push` after schema changes. Portal grants use raw SQL tables via the same URL.
# Pooled connection (hostname contains -pooler) — used by the app via Prisma Neon adapter.
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&pool_timeout=15
# Direct connection (no -pooler) — used by `prisma db push` / `prisma migrate`.
# DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Booking follow-up cron (disabled for now — do not set unless re-enabling)
# ENABLE_BOOKING_CRON=0
# CRON_SECRET=
# INQUIRY_FOLLOW_UP_DELAY_HOURS=2
# INQUIRY_ABANDON_AFTER_HOURS=24

# Smith.ai virtual receptionist (Phase 2)
# SMITH_AI_API_KEY=
# SMITH_AI_WEBHOOK_SECRET=             # Webhook auth header or HMAC secret
# NEXT_PUBLIC_ENABLE_SMITH_AI=0        # Set to 1 to load embed script
# NEXT_PUBLIC_SMITH_AI_WIDGET_ID=      # From Smith.ai dashboard

# SEO — canonical URLs in metadata (defaults to production domain if unset)
# NEXT_PUBLIC_SITE_URL=https://www.hitouchluxurycharter.com

# Demo portal testers (fixed UUIDs; idempotent): npm run seed:corporate-demo
# → demo-alpha@hitouch-portal.test, demo-beta@hitouch-portal.test

# Required to use /admin: staff username + password + secret used to sign the session cookie.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-secure-password
# Passwords with spaces must be quoted: ADMIN_PASSWORD="two words"
# ADMIN_SESSION_SECRET=   # long random string, e.g. openssl rand -hex 32

# Operations platform (trips, chauffeurs, Smith intake queue). Requires DATABASE_URL.
# USER_SESSION_SECRET=   # signs ADMIN + CHAUFFEUR user sessions (falls back to ADMIN_SESSION_SECRET)
# Seed demo users + trips: npm run seed:operations-demo
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=     # SMS on IN_ROUTE and ARRIVED (mock-logged in dev when unset)

# Corporate client portal (/portal/corporate): magic-link sessions (separate from admin cookie).
# CORPORATE_PORTAL_SESSION_SECRET=   # long random string, e.g. openssl rand -hex 32

# Transactional email (Resend) for magic links. If unset, `next dev` still returns the link in the
# portal UI (dev only). For `next start` without Resend, set:
# CORPORATE_PORTAL_DEV_RETURN_LINK=true
# RESEND_API_KEY=
# CORPORATE_PORTAL_FROM_EMAIL=HiTouch <onboarding@yourdomain.com>
# Optional absolute site URL for links in emails (defaults to request origin).
# NEXT_PUBLIC_SITE_URL=https://www.hitouchluxurycharter.com
